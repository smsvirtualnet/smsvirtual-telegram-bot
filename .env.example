# =============================================================================
#  SMS Virtual Telegram Bot — Environment Configuration
# =============================================================================
#
#  Copy this file to `.env` and fill in the values. The bot will refuse to
#  start if a required value is missing.
#
#  Never commit `.env` to a public repository. The installer (install.sh)
#  creates `.env` for you and sets reasonable file permissions.
#
# -----------------------------------------------------------------------------
#  Telegram
# -----------------------------------------------------------------------------

# Bot token from @BotFather (https://t.me/BotFather → /newbot).
# Format: 1234567890:ABC-DEF...
TELEGRAM_BOT_TOKEN=

# Your Telegram numeric user ID (find via @userinfobot).
# This account is the bot owner / admin.
ADMIN_TELEGRAM_ID=

# -----------------------------------------------------------------------------
#  SMS Virtual API
# -----------------------------------------------------------------------------

# Base URL for the SMS Virtual public API.
# Override only if you are pointing at a sandbox / mirror.
SMSVIRTUAL_API_BASE_URL=https://api.sms-virtual.net

# Default SMS Virtual API key for personal-mode installations.
# Multi-user installations can leave this blank — every Telegram user enters
# their own API key during /setup.
SMSVIRTUAL_API_KEY=

# Outbound HTTP request timeout (milliseconds).
SMSVIRTUAL_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
#  Bot mode
# -----------------------------------------------------------------------------

# personal | multi
#   personal — only ADMIN_TELEGRAM_ID can use the bot. One API key.
#   multi    — any allowed Telegram user can use the bot with their own key.
BOT_ACCESS_MODE=personal

# Optional comma-separated allowlist (Telegram user IDs).
# In multi mode, only these IDs (plus admin) can use the bot.
# Leave empty to let admin manage allowlist via the bot UI.
ALLOWED_TELEGRAM_IDS=

# -----------------------------------------------------------------------------
#  Behaviour
# -----------------------------------------------------------------------------

# Background OTP watcher — polls /v1/public/orders/getStatus/{id} for active
# activations and notifies users when an OTP arrives.
OTP_WATCHER_ENABLED=true
OTP_WATCHER_INTERVAL_MS=12000

# Catalog cache TTL (seconds). Reduces API calls for countries/operators/services.
CATALOG_CACHE_TTL_SECONDS=900

# Per-user rate limit (requests per window).
RATE_LIMIT_WINDOW_MS=10000
RATE_LIMIT_MAX=20

# Default behaviour when placing single-service orders.
ORDER_AUTO_SEARCH_SERVER=true
ORDER_DEFAULT_QUANTITY=1

# Logging.
LOG_LEVEL=info       # debug | info | warn | error
LOG_TO_FILE=false    # true → also append JSON logs to data/bot.log

# -----------------------------------------------------------------------------
#  Storage
# -----------------------------------------------------------------------------

# SQLite database file (created on first start).
DATABASE_FILE=./data/bot.sqlite

# Default UI language (only `en` is shipped today; Indonesian planned).
DEFAULT_LANGUAGE=en
