{
  "name": "smsvirtual-telegram-bot",
  "version": "1.0.0",
  "description": "Self-hosted Telegram bot for the SMS Virtual public API. Each customer/reseller runs their own bot using their own Telegram Bot Token and SMS Virtual API key.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "migrate": "node -e \"require('./src/db/migrations').runMigrations(require('./src/db/database').getDatabase())\"",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs smsvirtual-telegram-bot"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "axios": "1.7.9",
    "better-sqlite3": "11.5.0",
    "dotenv": "16.4.7",
    "node-cron": "3.0.3",
    "qrcode": "1.5.4",
    "telegraf": "4.16.3",
    "uuid": "11.0.3"
  },
  "license": "MIT",
  "private": true
}
